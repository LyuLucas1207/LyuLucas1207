# 本机 prod.local：Vite（build:prod-local）与 start.sh / stop.sh 共用
# 留空 VITE_API_URL = 与站点同源，由容器 nginx 反代到 host.docker.internal:10041

VITE_BUILD_ENV=prod
VITE_APP_ID=Lsr-Web-Prod-Local
VITE_PORT=10006
VITE_API_URL=
VITE_WS_URL=

LSR_WEB_IMAGE=lsr-web:prod-local
LSR_WEB_CONTAINER=LSR-Web-Prod-Local
LSR_WEB_PORT=10006
LSR_WEB_RESTART=unless-stopped
